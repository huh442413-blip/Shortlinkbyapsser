{
  "manifest_version": 3,
  "name": "VidyaRays Auto Bypass",
  "version": "1.0",
  "description": "Automatically bypasses timer verification on various shortlink sites",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://*.vidyarays.com/*",
    "*://*.tipsguru.in/*",
    "*://serox.vidyarays.com/*",
    "*://*.lksfy.com/*",
    "*://*.arolinks.com/*",
    "*://*.gplinks.com/*",
    "*://*.adrinolinks.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.vidyarays.com/*",
        "*://serox.vidyarays.com/*",
        "*://*.tipsguru.in/*",
        "*://*.lksfy.com/*",
        "*://*.arolinks.com/*",
        "*://*.gplinks.com/*",
        "*://*.adrinolinks.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "48": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
